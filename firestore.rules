rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function isMember(room) { return signedIn() && request.auth.uid in room.memberUids; }
    function immutableRoomFields() {
      return request.resource.data.schemaVersion == resource.data.schemaVersion
        && request.resource.data.hostUid == resource.data.hostUid
        && request.resource.data.roomId == resource.data.roomId
        && request.resource.data.caseId == resource.data.caseId
        && request.resource.data.contentVersion == resource.data.contentVersion
        && request.resource.data.maximumPlayers == resource.data.maximumPlayers
        && request.resource.data.seed == resource.data.seed
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.expiresAt == resource.data.expiresAt;
    }
    function isJoiningLobby() {
      return signedIn()
        && resource.data.status == 'lobby'
        && !(request.auth.uid in resource.data.memberUids)
        && request.auth.uid in request.resource.data.memberUids
        && request.resource.data.memberUids.size() == resource.data.memberUids.size() + 1
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberUids', 'members', 'revision'])
        && request.resource.data.members.diff(resource.data.members).addedKeys().hasOnly([request.auth.uid])
        && request.resource.data.members[request.auth.uid].uid == request.auth.uid
        && request.resource.data.members[request.auth.uid].displayName is string
        && request.resource.data.members[request.auth.uid].ready == false
        && request.resource.data.revision == resource.data.revision + 1;
    }
    function isLeavingLobby() {
      return isMember(resource.data)
        && request.auth.uid != resource.data.hostUid
        && resource.data.status == 'lobby'
        && !(request.auth.uid in request.resource.data.memberUids)
        && request.resource.data.memberUids.size() == resource.data.memberUids.size() - 1
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberUids', 'members', 'revision'])
        && request.resource.data.members.diff(resource.data.members).removedKeys().hasOnly([request.auth.uid])
        && request.resource.data.revision == resource.data.revision + 1;
    }
    function isUpdatingOwnReadyState() {
      return isMember(resource.data)
        && resource.data.status == 'lobby'
        && request.resource.data.status == 'lobby'
        && request.resource.data.memberUids == resource.data.memberUids
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members', 'revision'])
        && request.resource.data.members.diff(resource.data.members).affectedKeys().hasOnly([request.auth.uid])
        && request.resource.data.members[request.auth.uid].diff(resource.data.members[request.auth.uid]).affectedKeys().hasOnly(['ready'])
        && request.resource.data.members[request.auth.uid].ready is bool
        && request.resource.data.revision == resource.data.revision + 1;
    }
    function isHostLockingReadyLobby() {
      return signedIn()
        && request.auth.uid == resource.data.hostUid
        && resource.data.status == 'lobby'
        && request.resource.data.status == 'ready'
        && request.resource.data.session == null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'revision'])
        && request.resource.data.revision == resource.data.revision + 1;
    }

    match /rooms/{roomId} {
      allow create: if signedIn()
        && request.resource.data.schemaVersion == 'meducktion-room-v1'
        && request.resource.data.hostUid == request.auth.uid
        && request.resource.data.memberUids == [request.auth.uid]
        && request.resource.data.status == 'lobby'
        && request.resource.data.revision == 0;
      allow get: if isMember(resource.data) || (signedIn() && resource.data.status == 'lobby');
      allow list: if false;
      allow update: if immutableRoomFields()
        && request.resource.data.memberUids.size() <= resource.data.maximumPlayers
        && (isJoiningLobby() || isLeavingLobby() || isUpdatingOwnReadyState() || isHostLockingReadyLobby());
      allow delete: if signedIn() && request.auth.uid == resource.data.hostUid;
    }
  }
}
